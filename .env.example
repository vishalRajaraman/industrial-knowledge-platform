# ═══════════════════════════════════════════════════════════════════════════════
# InduStreakAI — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# CLOUD SERVICES (no self-hosting required for DB):
#   1. Qdrant Cloud (vector DB):    https://cloud.qdrant.io    [FREE cluster]
#   2. Neo4j AuraDB (knowledge graph): https://neo4j.com/aura  [FREE tier]
#   3. AWS S3 (object store):       https://aws.amazon.com/s3  [use any bucket]
#   4. Groq (LLM inference):        https://console.groq.com   [FREE API key]

# ─── LLM — Primary: Groq (FREE tier, no credit card) ─────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ─── LLM — Fallback 1: Google AI Studio (FREE tier, 1M token context) ─────────
GOOGLE_API_KEY=AIza_your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash-lite

# ─── LLM — Fallback 2: Ollama (local, for dev only) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Embeddings (local model, NO API key needed) ──────────────────────────────
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=1536          # Higher = richer semantics; 768 is fallback

# ─── Qdrant Cloud (Vector DB — cloud-hosted) ──────────────────────────────────
# Sign up FREE at https://cloud.qdrant.io → Create Cluster → Copy URL + API Key
QDRANT_URL=https://your_cluster_id.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=ikp_documents

# ─── Neo4j AuraDB (Knowledge Graph — cloud-hosted) ────────────────────────────
# Sign up FREE at https://neo4j.com/cloud/aura-free/
# Free tier: 200K nodes / 400K relationships / Always-on
NEO4J_URI=neo4j+s://your_instance_id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_aura_password_here

# ─── AWS S3 (Object Storage for raw documents) ────────────────────────────────
# Use any AWS account's S3 bucket. Files are stored here after ingestion.
# For local dev without S3: use MinIO instead (see MINIO_* below)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=ap-south-1
S3_BUCKET=industreak-raw-assets

# S3 Event Notifications (optional — for automatic ingestion trigger):
# Configure S3 → SQS notification in AWS Console, then set:
# SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/industreak-queue
# S3_POLL_INTERVAL=60   # fallback polling interval in seconds

# ─── MinIO (Local S3-compatible fallback — for dev without AWS) ───────────────
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# ─── P&ID YOLO Model (optional — set after fine-tuning) ──────────────────────
# PID_YOLO_MODEL=/path/to/your/fine_tuned_pid_yolov8.pt

# ─── Single MCP Server ────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO

# ─── Frontend / Orchestrator ──────────────────────────────────────────────────
MCP_SERVER_URL=http://mcp-server:8080   # unified server (was 6 separate servers)
NEXT_PUBLIC_API_URL=http://localhost:8000
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
APP_ENV=development
